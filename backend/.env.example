# SI-KASKUL Database Config
# Copy file ini ke backend/.env dan isi sesuai server lo

# === IN-MEMORY MODE (development, no DB needed) ===
# Kosongin semua DB_* biar pake in-memory

# === MySQL MODE (production, IDCloudHost) ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=si_kaskul

# === BACKEND CONFIG ===
PORT=3000
NODE_ENV=development